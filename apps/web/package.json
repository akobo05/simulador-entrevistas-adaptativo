{
  "name": "@warachikuy/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run copy:wasm && vite",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "pnpm run copy:wasm && tsc && vite build",
    "preview": "vite preview",
    "copy:wasm": "node --input-type=module -e \"import{cpSync,mkdirSync}from'node:fs';mkdirSync('public/mediapipe-wasm',{recursive:true});cpSync('../../packages/voice-pipeline/node_modules/@mediapipe/tasks-vision/wasm','public/mediapipe-wasm',{recursive:true});console.log('MediaPipe WASM copiado a public/mediapipe-wasm/');\""
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@warachikuy/shared-types": "workspace:*",
    "@warachikuy/voice-pipeline": "workspace:*",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "three": "^0.184.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^16.5.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.5"
  }
}
